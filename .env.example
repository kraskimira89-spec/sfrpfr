APP_ENV=local
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-random-string
APP_NAME=SFRFR
# Публичный HTTPS API (поддомен на VPS): для MAX webhook
PUBLIC_BASE_URL=https://api.taxi-doroga-dobra.ru
# CORS для витрины и кабинетов (через запятую)
CORS_ALLOWED_ORIGINS=https://taxi-doroga-dobra.ru,https://www.taxi-doroga-dobra.ru,https://cabinet.taxi-doroga-dobra.ru,https://admin.taxi-doroga-dobra.ru

# Supabase (основная БД + Auth + Storage)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Локальный Postgres (если без Supabase cloud)
# DATABASE_URL=postgresql+psycopg://sfrfr:sfrfr@localhost:5432/sfrfr

# Хранилище документов
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage/uploads
# STORAGE_BACKEND=supabase
# SUPABASE_STORAGE_BUCKET=pension-docs

# OCR
OCR_ENGINE=tesseract
TESSERACT_LANG=rus+eng
# YANDEX_OCR_API_KEY=
# YANDEX_OCR_FOLDER_ID=

# AI — Yandex AI Studio (основной)
AI_PROVIDER=yandex
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt/latest
YANDEX_BASE_URL=https://llm.api.cloud.yandex.net/v1
# OpenAI — только для локальных экспериментов
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# MAX messenger (диалог с клиентом)
MAX_BOT_TOKEN=
MAX_API_BASE=https://platform-api2.max.ru
MAX_WEBHOOK_SECRET=
# Публичная ссылка/deeplink на бота (+ мини-приложение) для кнопки на лендинге WP
MAX_PUBLIC_BOT_URL=https://max.ru/id8905998693_1_bot?startapp
# HTTPS URL мини-приложения (поле в кабинете MAX → Расширенные настройки)
MAX_MINIAPP_URL=https://taxi-doroga-dobra.ru/app/
# Публичный URL веб-кабинета клиента
CABINET_PUBLIC_URL=https://cabinet.taxi-doroga-dobra.ru

# ПДн / безопасность (152-ФЗ)
PII_ENCRYPTION_KEY=
DATA_RETENTION_DAYS=90
REQUIRE_CONSENT=true

# Тарифы (метаданные продукта)
DEFAULT_DIAGNOSTIC_PRICE_RUB=3000
SUCCESS_FEE_PERCENT=10
# Taganay CRM: шаблон ссылки на карточку ({id} = crm_external_id) или базовый URL
TAGANAY_CASE_URL_TEMPLATE=https://taganay.clientbase.ru/
# Исходящий webhook/API для лидов и этапов (минимум контактов, связь по case_id)
TAGANAY_WEBHOOK_URL=
TAGANAY_API_TOKEN=

# Google Sheets (ТЗ-06): только обезличенные поля, без ФИО/телефона/СНИЛС
# 1) API (рекомендуется): service account + ID таблицы
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET=Analytics
# Путь к JSON ключу, например secrets/google-sheets-sa.json — или весь JSON в одну строку
GOOGLE_SHEETS_CREDENTIALS_JSON=
# 2) Fallback: Apps Script webhook
GOOGLE_SHEETS_WEBHOOK_URL=

# ЮKassa (чеки / redirect confirmation)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_API_BASE=https://api.yookassa.ru/v3
YOOKASSA_RETURN_URL=
# true — отправлять чек 54-ФЗ, если у клиента есть email
YOOKASSA_SEND_RECEIPT=false

# Публичный лид с WordPress → POST /api/public/leads (заголовок X-Public-Lead-Token)
PUBLIC_LEAD_TOKEN=

CABINET_PUBLIC_URL=https://cabinet.taxi-doroga-dobra.ru

# Эксплуатация (ТЗ-05): токен для GET /ops/status и порог алерта failed-дел
OPS_MONITOR_TOKEN=
OPS_FAILED_ALERT_THRESHOLD=1

# Первый admin кабинета сотрудников (после миграций):
#   sfrfr staff-grant --email you@company.com --role admin --invite
# Список: sfrfr staff-list
# Sheets sync: sfrfr sheets-sync
# Taganay sync одного дела: sfrfr taganay-sync --case-id …