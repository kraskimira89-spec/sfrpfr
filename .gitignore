# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.env/
*.egg

# Tests / linters
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Env & secrets
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
secrets/
**/google-sheets-sa.json
**/google*credentials*.json

# Next.js apps
apps/*/node_modules/
apps/*/.next/
apps/*/out/

# ПДн и рабочие файлы клиентов — никогда в git
storage/uploads/*
storage/processed/*
storage/knowledge_inbox/
storage/cases.json
storage/cases.tmp
!storage/uploads/.gitkeep
!storage/processed/.gitkeep
*.pdf
*.jpg
*.jpeg
*.png
!assets/**/*.png
!tests/fixtures/sample_docs/.gitkeep
!docs/**

# Сгенерированные Word — не в git (сборка: scripts/render_landing_tz_docx.py)
*.docx
~$*.docx

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Docker / local DB
pgdata/
supabase/.branches/
supabase/.temp/

# Local CLI logs
supabase-start.log
*.log
